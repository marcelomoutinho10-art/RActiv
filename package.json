{
  "name": "raciv",
  "version": "1.0.0",
  "description": "RActiv - Registo de Atividades",
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "cd client && npm install && npm run build",
    "start": "node src/index.js",
    "start:prod": "npx prisma migrate deploy && node src/seed.js && node src/index.js",
    "dev": "node src/index.js",
    "postinstall": "npx prisma generate"
  },
  "dependencies": {
    "@prisma/client": "5.10.2",
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "express": "4.18.3",
    "jsonwebtoken": "9.0.2",
    "prisma": "5.10.2"
  }
}
